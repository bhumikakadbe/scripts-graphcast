# ============================================================
#  scripts-graphcast — .gitignore
# ============================================================

# --- Python bytecode and build artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so
*.whl

# --- Virtual environments ---
.venv/
venv/
env/
.env
.conda/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- IDE and editor files ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# --- OS-specific files ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.lnk

# ============================================================
#  DATA — Never commit large downloaded ERA5/IMD files
# ============================================================
data/ERA5/raw/
data/ERA5/processed/
data/IMD/
data/merged/
data/*.nc
data/*.grib

# ============================================================
#  LOGS — Auto-generated runtime logs
# ============================================================
logs/*.log
logs/*.csv
logs/*.png
logs/*.md
logs/*.json
# Keep the logs/ folder itself tracked
!logs/.gitkeep

# ============================================================
#  CHECKPOINTS — Keep base model, ignore generated ones
# ============================================================
# Ignore year-by-year fine-tuned checkpoints (can be regenerated)
checkpoints/model_20*.nc
checkpoints/model_original.nc
checkpoints/model_compressed.nc

# Keep essential base files (normalization stats + base model)
!checkpoints/fine_tuned_model.nc
!checkpoints/diffs_stddev_by_level.nc
!checkpoints/mean_by_level.nc
!checkpoints/stddev_by_level.nc
!checkpoints/.gitkeep

# Large ERA5 template dataset — too big for GitHub (126 MB), re-download via era5_downloader.py
checkpoints/source-era5_*.nc

# ============================================================
#  COMPRESSION — Ignore generated PCA models and outputs
# ============================================================
compression/pca_models/*.pkl
compression/pca_models/*.joblib
compression/outputs/

# ============================================================
#  STATIC OUTPUTS — Ignore API-generated forecast images
# ============================================================
static/outputs/
static/*.png
static/*.jpg

# ============================================================
#  GRAPHCAST EXAMPLE INFO — Exclude from repo
# ============================================================
graphcast_example_info/

# ============================================================
#  TEMPORARY AND GENERATED FILES
# ============================================================
*.tmp
*.temp
*.bak
*.orig
*.log
*.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# --- Profiling ---
*.prof
*.lprof
*.stats
